{
	"name": "@eliashaeussler/typo3-badges",
	"description": "Frontend for TYPO3 Badges, a Symfony project that provides endpoints for beautiful TYPO3 badges.",
	"version": "1.8.1",
	"license": "GPL-3.0-or-later",
	"repository": "https://github.com/eliashaeussler/typo3-badges.git",
	"private": true,
	"author": {
		"name": "Elias Häußler",
		"email": "elias@haeussler.dev",
		"url": "https://haeussler.dev"
	},
	"homepage": "https://typo3-badges.dev",
	"devDependencies": {
		"@babel/core": "7.29.7",
		"@babel/preset-env": "7.29.7",
		"@eslint/js": "10.0.1",
		"@symfony/webpack-encore": "6.0.0",
		"@tailwindcss/postcss": "4.3.1",
		"@types/node": "25.9.4",
		"autoprefixer": "10.5.0",
		"eslint": "10.5.0",
		"globals": "17.6.0",
		"knip": "6.16.1",
		"npm-run-all": "^4.1.5",
		"postcss-import": "16.1.1",
		"postcss-loader": "8.2.1",
		"stylelint": "17.13.0",
		"stylelint-config-standard": "40.0.0",
		"swagger-spec-validator": "^6.0.0",
		"tailwindcss": "4.3.1",
		"tailwindcss-crossbrowser-touch": "1.1.2",
		"tailwindcss-selection-variant": "0.1.0",
		"webpack": "5.107.2",
		"webpack-cli": "6.0.1"
	},
	"dependencies": {
		"@fontsource/indie-flower": "5.2.7",
		"@fontsource/jetbrains-mono": "5.2.8",
		"@fontsource/lato": "5.2.7",
		"clipboard": "2.0.11",
		"flowbite": "3.1.2"
	},
	"scripts": {
		"build": "encore prod",
		"start": "encore dev --watch",
		"check": "npm-run-all check:deps check:schema check:style",
		"check:deps": "knip -c build/checks/knip.json",
		"check:schema": "swagger-spec-validator spec/typo3-badges.oas3.yaml",
		"check:style": "npm-run-all check:style:css check:style:js",
		"check:style:css": "stylelint 'assets/**/*.css'",
		"check:style:js": "eslint 'assets/**/*.js' './*.js'",
		"ci": "npm audit && npm run check",
		"fix": "npm run fix:style",
		"fix:style": "npm-run-all fix:style:css fix:style:js",
		"fix:style:css": "stylelint 'assets/**/*.css' --fix",
		"fix:style:js": "eslint 'assets/**/*.js' './*.js' --fix"
	}
}
