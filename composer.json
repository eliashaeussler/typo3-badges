{
	"name": "eliashaeussler/typo3-badges",
	"description": "A Symfony project that provides endpoints for beautiful TYPO3 badges.",
	"license": "GPL-3.0-or-later",
	"type": "project",
	"authors": [
		{
			"name": "Elias Häußler",
			"email": "elias@haeussler.dev",
			"homepage": "https://haeussler.dev",
			"role": "Maintainer"
		}
	],
	"homepage": "https://typo3-badges.dev",
	"require": {
		"php": "~8.5.0",
		"ext-hash": "*",
		"ext-json": "*",
		"cweagans/composer-patches": "2.0.0",
		"nyholm/psr7": "1.8.2",
		"sentry/sentry-symfony": "5.10.0",
		"symfony/apache-pack": "1.0.1",
		"symfony/asset": "8.1.0",
		"symfony/cache": "8.1.1",
		"symfony/cache-contracts": "3.7.1",
		"symfony/console": "8.1.1",
		"symfony/css-selector": "8.1.0",
		"symfony/dependency-injection": "8.1.1",
		"symfony/dotenv": "8.1.0",
		"symfony/flex": "2.11.0",
		"symfony/framework-bundle": "8.1.1",
		"symfony/http-client": "8.1.1",
		"symfony/http-client-contracts": "3.7.1",
		"symfony/http-foundation": "8.1.1",
		"symfony/http-kernel": "8.1.1",
		"symfony/routing": "8.1.0",
		"symfony/runtime": "8.1.0",
		"symfony/security-bundle": "8.1.1",
		"symfony/service-contracts": "3.7.1",
		"symfony/web-link": "8.1.0",
		"symfony/web-profiler-bundle": "8.1.1",
		"symfony/webpack-encore-bundle": "2.4.1",
		"symfony/yaml": "8.1.1",
		"twig/twig": "3.27.1"
	},
	"require-dev": {
		"armin/editorconfig-cli": "2.2.1",
		"eliashaeussler/php-cs-fixer-config": "3.1.0",
		"eliashaeussler/phpstan-config": "4.0.0",
		"eliashaeussler/rector-config": "4.0.0",
		"eliashaeussler/version-bumper": "4.0.3",
		"ergebnis/composer-normalize": "2.52.0",
		"phpstan/extension-installer": "1.4.3",
		"phpstan/phpstan-symfony": "2.0.20",
		"phpunit/phpunit": "13.2.1",
		"shipmonk/composer-dependency-analyser": "1.8.4",
		"symfony/browser-kit": "8.1.1",
		"symfony/filesystem": "8.1.0",
		"symfony/phpunit-bridge": "8.1.1"
	},
	"replace": {
		"symfony/polyfill-ctype": "*",
		"symfony/polyfill-iconv": "*",
		"symfony/polyfill-php72": "*",
		"symfony/polyfill-php73": "*",
		"symfony/polyfill-php74": "*",
		"symfony/polyfill-php80": "*",
		"symfony/polyfill-php81": "*",
		"symfony/polyfill-php82": "*",
		"symfony/polyfill-php83": "*",
		"symfony/polyfill-php84": "*"
	},
	"conflict": {
		"symfony/symfony": "*"
	},
	"autoload": {
		"psr-4": {
			"App\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"App\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/package-versions-deprecated": true,
			"cweagans/composer-patches": true,
			"eliashaeussler/version-bumper": true,
			"ergebnis/composer-normalize": true,
			"phpstan/extension-installer": true,
			"symfony/flex": true,
			"symfony/runtime": true
		},
		"optimize-autoloader": true,
		"preferred-install": {
			"*": "dist"
		},
		"sort-packages": true
	},
	"extra": {
		"patches": {
			"symfony/webpack-encore-bundle": {
				"Fix Symfony 8.1 DependencyInjection deprecation warning": "https://patch-diff.githubusercontent.com/raw/symfony/webpack-encore-bundle/pull/258.patch"
			}
		},
		"symfony": {
			"allow-contrib": false,
			"require": "~8.1.0"
		},
		"version-bumper": {
			"config-file": "build/release/version-bumper.yaml"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@auto-scripts"
		],
		"post-update-cmd": [
			"@auto-scripts"
		],
		"auto-scripts": {
			"assets:install %PUBLIC_DIR%": "symfony-cmd",
			"cache:clear --no-optional-warmers": "symfony-cmd"
		},
		"check": [
			"@check:deps",
			"@check:refactor",
			"@check:static",
			"@check:style"
		],
		"check:deps": "composer-dependency-analyser --config build/checks/composer-dependency-analyser.php",
		"check:refactor": [
			"@check:refactor:php"
		],
		"check:refactor:php": "@refactor:php --dry-run",
		"check:static": "phpstan analyse -c build/checks/phpstan.php",
		"check:style": [
			"@check:style:composer",
			"@check:style:editorconfig",
			"@check:style:php",
			"@check:style:twig"
		],
		"check:style:composer": "@fix:composer --dry-run",
		"check:style:editorconfig": "ec",
		"check:style:php": "@fix:php --dry-run",
		"check:style:twig": "bin/console lint:twig templates",
		"ci": [
			"@composer validate",
			"@composer audit",
			"@check:deps",
			"@check:refactor",
			"@check:static --error-format github",
			"@check:style",
			"@composer recipes --outdated"
		],
		"fix": [
			"@fix:composer",
			"@fix:editorconfig",
			"@fix:php"
		],
		"fix:composer": "@composer normalize",
		"fix:editorconfig": "@check:style:editorconfig --fix",
		"fix:php": "php-cs-fixer fix --config build/checks/.php-cs-fixer.php",
		"refactor": [
			"@refactor:php"
		],
		"refactor:php": "rector process -c build/checks/rector.php",
		"test": "@test:coverage --no-coverage",
		"test:coverage": "phpunit -c build/tests/phpunit.xml"
	}
}
